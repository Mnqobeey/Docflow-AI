PORT=3001
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_URL=http://localhost:5173

# Required backend-only Supabase credentials.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional primary LLM provider. If omitted/failing, DocFlow still works.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Optional secondary LLM fallback provider. Free models are limited.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1

# Optional AI provider timeout in milliseconds.
AI_PROVIDER_TIMEOUT_MS=18000

# Keep real provider smoke tests opt-in so local checks do not spend quota.
SMOKE_REAL_AI=0
